# ──────────────────────────────────────────────
# FundaConnect — Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# --- App ---
ENVIRONMENT=development   # development | staging | production
SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:3001
API_BASE_URL=http://localhost:8000

# --- Database (PostgreSQL) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fundaconnect
POSTGRES_USER=fundaconnect
POSTGRES_PASSWORD=fundaconnect
DATABASE_URL=postgresql+asyncpg://fundaconnect:fundaconnect@localhost:5432/fundaconnect

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Meilisearch ---
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_MASTER_KEY=masterKey

# --- JWT ---
JWT_SECRET_KEY=change-me-to-another-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
EMAIL_VERIFICATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60
TERMS_OF_SERVICE_VERSION=2026-03-29
PRIVACY_POLICY_VERSION=2026-03-29
MARKETING_CONSENT_VERSION=2026-03-29

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- PayFast ---
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_RETURN_URL=http://localhost:3001/parent
PAYFAST_CANCEL_URL=http://localhost:3001/parent
# For local webhook testing, set this to your tunnel URL, e.g.
# https://your-subdomain.ngrok-free.app/api/v1/bookings/payfast/itn
PAYFAST_NOTIFY_URL=

# --- Ozow ---
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
OZOW_API_KEY=
OZOW_SANDBOX=true

# --- AWS S3 ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
AWS_S3_BUCKET=fundaconnect-documents
MALWARE_SCAN_MODE=off
CLAMSCAN_PATH=clamscan

# --- Email (Amazon SES / Postmark) ---
EMAIL_FROM=noreply@fundaconnect.co.za
EMAIL_FROM_NAME=FundaConnect
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- SMS (BulkSMS / Africa's Talking) ---
BULKSMS_USERNAME=
BULKSMS_PASSWORD=
# or Africa's Talking:
AT_API_KEY=
AT_USERNAME=

# --- Video (Daily.co) ---
DAILY_API_KEY=

# --- Platform ---
PLATFORM_COMMISSION_RATE=0.175
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:8000

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3001
